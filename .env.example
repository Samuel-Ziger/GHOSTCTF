# Copiar para .env e preencher (nunca commitar .env)

# ── Postgres direto (Supabase: Settings → Database → URI ou Session Pooler para IPv4)
# A password na URL tem de estar codificada se tiver @, #, etc. (encodeURIComponent)
# Exemplo: postgresql://postgres:SENHA_ENCODADA@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=

# ── Alternativa: API Supabase (sem DATABASE_URL)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

PORT=3847

# VirusTotal — subdomínios (módulo `virustotal` na UI)
# VIRUSTOTAL_API_KEY=

# Webhook JSON opcional após cada recon gravado
# GHOSTCTF_WEBHOOK_URL=https://discord.com/api/webhooks/...
# (legacy: GHOSTRECON_WEBHOOK_URL)

# Rate limit POST /api/recon/stream (0 = desligado)
# GHOSTCTF_RL_MAX=12
# GHOSTCTF_RL_WINDOW_MS=60000
# (legacy: GHOSTRECON_RL_*)

# Common Crawl — URL completa do CDX API (opcional; senão usa collinfo)
# GHOSTCTF_CC_CDX_API=https://index.commoncrawl.org/CC-MAIN-2025-51-index
# (legacy: GHOSTRECON_CC_CDX_API)

# SQLite local (só se não usares Supabase)
# GHOSTCTF_DB=
# (legacy: GHOSTRECON_DB)

# ── Kali mode / wpscan (WordPress enumeration) ──
# Se o passivo detectar WordPress, o Kali mode pode rodar wpscan (apenas enumeração).
# GHOSTCTF_WPSCAN_DETECTION_MODE=mixed
# GHOSTCTF_WPSCAN_TIMEOUT_MS=240000
# (legacy: GHOSTRECON_WPSCAN_*)
